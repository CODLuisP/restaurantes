# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY: API key de Google Cloud Console con
# Maps JavaScript API + Geocoding API + Places API habilitadas.
# Se usa en Configuración > Información del negocio > Ubicación.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_API_KEY"

# API_URL: URL base del backend RestaurantesAPI (.NET). NextAuth lo llama
# desde el servidor (Route Handler / Server Actions), nunca desde el cliente.
API_URL="http://localhost:5004"

# NEXT_PUBLIC_API_URL: misma URL, pero accesible desde componentes cliente
# ('use client') para llamar directo al backend (ej. módulos CRUD del dashboard).
NEXT_PUBLIC_API_URL="http://localhost:5004"

# AUTH_SECRET: clave usada por NextAuth para firmar/cifrar la sesión (JWT).
# Generar una nueva por entorno: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
AUTH_SECRET="MY_AUTH_SECRET"

# SUNAT_API_URL / SUNAT_API_TOKEN: Proveedor OSE/SUNAT de facturación electrónica
# (Nubefact, Facturactiva, etc.) para emitir Boletas y Facturas desde /cobrar.
# Si se dejan vacías, el endpoint /api/emitir-comprobante opera en MODO DEMO
# (simula la aceptación de SUNAT sin enviar nada real).
SUNAT_API_URL=""
SUNAT_API_TOKEN=""
